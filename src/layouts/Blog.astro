import HeadCog from '../components/HeadCog.astro';
import ModelCog from '../components/ModelCog.astro';
import FooterCog from '../components/FooterCog.astro';
import HeadingCog from '../components/HeadingCog.astro';
const posts = (await Astro.glob('../pages/blog/*.{md,}')).sort(
	(a, b) => new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf()
);
---

<!DOCTYPE html>
<html lang="en">
 <HeadCog/>
 <body>
  <HeadingCog/>
  <ModelCog
   modelURL="https://angeldollface.art/assets/models/StageInfinity.glb"
   textureURL="https://angeldollface.art/assets/images/matcaps/03.png"
   symbolName="Infinity"
   spinAxis="z"
  />
  <div class="itemList">
  {posts.map(
   (post) => (
   <h2 class="itemList">
    <a class="itemList" href={post.url}>
     {post.frontmatter.title}
    </a>
   </h2>
    )
   )
  }
  <br/>
  <br/>
  </div>
</body>
</html>