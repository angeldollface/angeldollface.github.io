---
import HeadCog from "../components/HeadCog.astro";
import ModelCog from '../components/ModelCog.astro';
import HeadingCog from "../components/HeadingCog.astro";
export interface Props {
	content: {
		title: string;
		description: string;
		dateTime: string;
		tags: string;
	};
}
const {
	content: { 
		title, 
		description, 
		dateTime, 
		tags 
	}
} = Astro.props;
---

<html lang="en">
 <HeadCog/>
 <body>
  <HeadingCog/>
  <ModelCog
   modelURL="https://angeldollface.art/assets/models/StageInfinity.glb"
   textureURL="https://angeldollface.art/assets/images/matcaps/03.png"
   symbolName="Infinity"
   spinAxis="z"
  />
  <div class="itemContent">
   <div class="content">
	<h2>{title}</h2>
   	<p>{dateTime}</p>
   	<slot/>
   </div>
   <br/>
  </div>
 </body>
</html>