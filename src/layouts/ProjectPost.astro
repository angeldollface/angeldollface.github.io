import HeadCog from '../components/HeadCog.astro';
import ModelCog from '../components/ModelCog.astro';
import FooterCog from '../components/FooterCog.astro';
import HeadingCog from "../components/HeadingCog.astro";
export interface Props {
	content: {
		title: string;
		description: string;
	};
}
const {
	content: { 
		title, 
		description
	}
} = Astro.props;
---

<html lang="en">
 <HeadCog/>
 <body>
  <HeadingCog/>
  <ModelCog
   modelURL="https://angeldollface.art/assets/models/StageCode.glb"
   textureURL="https://angeldollface.art/assets/images/matcaps/02.png"
   symbolName="Six"
   spinAxis="z"
  />
   <div class="content">
    <h2>{title}</h2>
   <p>{description}</p>
   <slot/>
   </div>
   <br/>
  <FooterCog/>
 </body>
</html>