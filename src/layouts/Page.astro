import HeadCog from "../components/HeadCog.astro";
import ModelCog from '../components/ModelCog.astro';
import FooterCog from '../components/FooterCog.astro';
import HeadingCog from "../components/HeadingCog.astro";
export interface Props {
	content: {
		title: string;
		description: string;
	};
}
const {
	content: { 
		title, 
		description
	}
} = Astro.props;
---

<html lang="en">
 <HeadCog
  name={title}
  description={description}
 />
 <body>
  <HeadingCog/>
  <ModelCog
   modelURL="https://angeldollface.art/assets/models/StageMoon.glb"
   textureURL="https://angeldollface.art/assets/images/matcaps/01.png"
   symbolName="Moon"
   spinAxis="z"
  />
   <div class="content">
   	<slot/>
   </div>
   <br/>
  <FooterCog/>
 </body>
</html>