import * as site from '../config';

const logoPath: string = site.logoPath;
const name: string = site.name;
const menuString: string = site.menuString;
const navLinks: Object = site.navLinks;
const closingText: string = site.closingText;
---

<script>
import { 
    openNav,
    closeNav
} from '../mods/ts/nav';
globalThis.openNav = openNav
globalThis.closeNav = closeNav
</script>

<div class="header">
 <h1 onclick="openNav();">{name}</h1>
</div>

<div class="nav" id="nav">
 <ul class="nav">
 {Object.entries(navLinks).map(([key, val]) => (
  <li class="nav">
   <a class="nav" href={val}>{key}</a>
  </li>
 ))}
  <li class="nav">
   <a class="nav" onclick="closeNav();">{closingText}</a>
  </li>
 </ul>
</div>
