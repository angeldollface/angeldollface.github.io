import * as site from '../config';
const name: string = site.name;
const navLinks: Object = site.navLinks;
---
<script>
import { 
    openNav,
    closeNav
} from '../mods/nav';
globalThis.openNav = openNav
globalThis.closeNav = closeNav
</script>
<div class="header">
 <h1>{name}</h1>
 <button class="menu" onclick="openNav();">
  <i class="fa fa-bars"></i>
 </button>
 <div class="nav" id="nav">
  <ul class="nav">
   {
    Object.entries(navLinks).map(
     ([key, val]) => (
      <li class="nav">
       <a class="nav" href={val}>{key}</a>
      </li>
      )
     )
    }
   </ul>
  </div>
</div>