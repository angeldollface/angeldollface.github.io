import * as site from '../config';
const fiveSevenIcon: string = site.fiveSevenIcon;
const sixZeroIcon: string = site.sixZeroIcon;
const sevenTwoIcon: string = site.sevenTwoIcon;
const sevenSixIcon: string = site.sevenSixIcon;
const oneOneFourIcon: string = site.oneOneFourIcon;
const oneTwoZeroIcon: string = site.oneTwoZeroIcon;
const oneFourFourIcon: string = site.oneFourFourIcon;
const oneFiveTwoIcon: string = site.oneFiveTwoIcon;
const oneEightZeroIcon: string = site.oneEightZeroIcon;
const oneNineTwoIcon: string = site.oneNineTwoIcon;
const threeTwoIcon: string = site.threeTwoIcon;
const nineSixIcon: string = site.nineSixIcon;
const oneSixIcon: string = site.oneSixIcon;
const name: string = site.name;
const description: string = site.description;
const banner: string = site.banner;
---

<head>
    <meta charset="UTF-8"/>
    <title>{name}</title>
    <meta name="robots" content={description}/>
    <meta name="msapplication-TileColor" content="#000000">
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="description" content={description}/>
    <link rel="apple-touch-icon" sizes="57x57" href={fiveSevenIcon}/>
    <link rel="apple-touch-icon" sizes="60x60" href={sixZeroIcon}/>
    <link rel="apple-touch-icon" sizes="72x72" href={sevenTwoIcon}/>
    <link rel="apple-touch-icon" sizes="76x76" href={sevenSixIcon}/>
    <link rel="apple-touch-icon" sizes="114x114" href={oneOneFourIcon}/>
    <link rel="apple-touch-icon" sizes="120x120" href={oneTwoZeroIcon}/>
    <link rel="apple-touch-icon" sizes="144x144" href={oneFourFourIcon}/>
    <link rel="apple-touch-icon" sizes="152x152" href={oneFiveTwoIcon}/>
    <link rel="apple-touch-icon" sizes="180x180" href={oneEightZeroIcon}/>
    <link rel="icon" type="image/png" sizes="192x192"  href={oneNineTwoIcon}/>
    <link rel="icon" type="image/png" sizes="32x32" href={threeTwoIcon}/>
    <link rel="icon" type="image/png" sizes="96x96" href={nineSixIcon}/>
    <link rel="icon" type="image/png" sizes="16x16" href={oneSixIcon}/>
    <meta name="msapplication-TileImage" content={oneFourFourIcon }/>
    <meta property="og:image:type" content="image/png"/>
    <meta name="twitter:image:type" content="image/png"/>
    <meta property="og:image" content={banner}/>
    <meta property="twitter:image" content={banner}/>
    <meta property="og:name" content={name}/>
    <meta property="og:description" content={description}/>
    <meta name="twitter:name" content={name}/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:image:alt" content={description}/>
    <meta name="twitter:description" content={description}/>
    <link rel="stylesheet" type="text/css" href="/assets/css/index.css"/>
   </head>