import * as site from '../config';
const socialMediaIcons: Object = site.socialMediaLinks;
const footerText: string = site.footerText;
---
<div class="footer">
    <p class="footer">{footerText}</p>
    <ul class="footer">
      {Object.entries(socialMediaIcons).map(([key, val]) => (
        <li class="footer">
          <a class="footer" href={val}>
            <i class={key}></i>
          </a>
        </li>
       ))}
    </ul>
   </div>